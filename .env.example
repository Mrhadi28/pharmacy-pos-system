# Copy this file to ".env" in the repo root (same folder as docker-compose.yml).
# cp .env.example .env   (Mac/Linux)   or copy manually on Windows

# --- Supabase Postgres (recommended for hosted + Realtime) ---
# Dashboard → Project Settings → Database:
#   • Copy "Session pooler" URI (port 5432) OR "Direct connection" — both work with this app.
#   • Do NOT use "Transaction pooler" (port 6543) for `pnpm --filter @workspace/db run push`.
#   • URI must include ssl (Supabase strings usually end with ?sslmode=require).
# Same project → Settings → API: Project URL + anon key → paste into VITE_SUPABASE_* below.
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# After DATABASE_URL is set, from repo root:
#   npx pnpm@9 --filter @workspace/db run push
# Then Supabase → SQL Editor → run scripts/supabase-realtime-publication.sql (Realtime UI sync).

# Local Docker Postgres (optional; see docker-compose.yml)
DATABASE_URL=postgresql://pharma:pharma_dev@127.0.0.1:5432/pharma_wise

# API server
PORT=8080
SESSION_SECRET=change-this-before-production
SKIP_SUBSCRIPTION_CHECK=0

# Frontend (Vite) — only needed if you do not rely on defaults in vite.config.ts
# PORT=5173
# BASE_PATH=/
VITE_SKIP_SUBSCRIPTION_CHECK=0

# After Docker Desktop is installed: from repo root run
#   npx pnpm@9 run db:setup
# (starts Postgres via docker compose, waits for port 5432, runs drizzle push)

# --- Billing (new pharmacies = unpaid until you activate) ---
SUBSCRIPTION_AMOUNT_PKR=12000
BILLING_ADMIN_SECRET=change-to-long-random-secret
# WhatsApp number digits only with country code, e.g. 923001234567
PAYMENT_WHATSAPP=
PAYMENT_NOTE=JazzCash ya bank transfer ke baad receipt WhatsApp par bhejein.
PAYMENT_ACCOUNT_TITLE=
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_BANK_NAME=
PAYMENT_IBAN=

# Optional support email pipeline (for Account Center messages)
SUPPORT_TO_EMAIL=contact.devarion@gmail.com
SUPPORT_FROM_EMAIL=
SUPPORT_SMTP_HOST=
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_USER=
SUPPORT_SMTP_PASS=

# After drizzle push, existing test pharmacies ko unblock karne ke liye (optional):
# UPDATE pharmacies SET subscription_paid_until = NOW() + INTERVAL '400 days' WHERE subscription_paid_until IS NULL;

# Production reverse proxy: WebSocket path /api/realtime needs Upgrade headers (see Caddy/nginx docs).

# --- Supabase client (Realtime in browser; same project as DATABASE_URL above) ---
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...   (Project API → anon public)
# VITE_SUPABASE_PUBLISHABLE_KEY=  (optional fallback)
# Optional tuning when using Supabase pooler:
# DATABASE_POOL_MAX=15
# DATABASE_CONNECT_TIMEOUT_MS=15000

# --- Production deploy (VPS / single Node process) ---
# 1) Set DATABASE_URL to your host Postgres (Supabase: use “Session” pooler URI, ?sslmode=require).
# 2) Strong SESSION_SECRET; set BILLING_ADMIN_SECRET if you use billing activate.
# 3) From repo root (so .env is found):
#      npx pnpm@9 install --ignore-scripts
#      npx pnpm@9 run deploy:build
#      npx pnpm@9 --filter @workspace/db run push
# 4) Run API (serves SPA + /api + WebSocket) from repo root:
#      set NODE_ENV=production
#      set TRUST_PROXY=1
#      set SESSION_COOKIE_SECURE=1
#    (Local prod test over HTTP only: SESSION_COOKIE_SECURE=0)
#      npx pnpm@9 --filter @workspace/api-server run start
#    Or: node artifacts/api-server/dist/index.cjs
# 5) Reverse proxy (Caddy/nginx): TLS terminate, proxy_pass to 127.0.0.1:8080 with Upgrade for WebSockets.
#    Paths: / and /api and /api/realtime (WS) same upstream.
# 6) Optional: STATIC_DIST=/absolute/path/to/pharma-pos/dist/public if build output is not default layout.
# 7) Supabase Realtime: only works if DATABASE_URL is that project’s DB and tables are in publication supabase_realtime.
